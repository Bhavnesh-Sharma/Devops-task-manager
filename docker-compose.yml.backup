version: "3.9"

services:
  mongo:
    image: mongo:7
    container_name: devops-task-manager-mongo
    restart: unless-stopped
    environment:
      MONGO_INITDB_DATABASE: devops_task_manager
    volumes:
      - mongo-data:/data/db
    ports:
      - "27017:27017"

  api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: devops-task-manager-api
    restart: unless-stopped
    environment:
      NODE_ENV: production
      PORT: 3000
      MONGO_URI: mongodb://mongo:27017/devops_task_manager
    ports:
      - "3000:3000"
    depends_on:
      - mongo

volumes:
  mongo-data:


